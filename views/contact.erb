<div class="hero">
  <h1>Contact</h1>
  <p>Get in touch — we'd love to hear from you.</p>
</div>

<div class="grid-2">
  <div class="card">
    <h3>Send a Message</h3>
    <form id="contact-form" onsubmit="submitForm(event)">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" placeholder="Your name" required>
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" placeholder="you@example.com" required>
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" placeholder="What's on your mind?" required></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;">Send Message</button>
    </form>
    <div id="form-success" style="display:none; text-align:center; padding:2rem; color:var(--success);">
      <div style="font-size:2rem; margin-bottom:0.5rem;">&#10003;</div>
      <strong>Message sent!</strong>
      <p style="color:var(--text-muted); margin-top:0.25rem;">Thanks for reaching out.</p>
    </div>
  </div>

  <div>
    <div class="card">
      <h3>Other Ways to Reach Us</h3>
      <div style="line-height:2.2; color:var(--text-muted);">
        <p>&#128231; hello@example.com</p>
        <p>&#127760; github.com/hello-world</p>
        <p>&#128205; The Internet, Everywhere</p>
      </div>
    </div>
    <div class="card">
      <h3>FAQ</h3>
      <details style="margin-bottom:0.75rem;">
        <summary style="cursor:pointer; font-weight:500;">Is this app open source?</summary>
        <p style="margin-top:0.5rem; color:var(--text-muted); padding-left:1rem;">Yes! Check out the repo on GitHub.</p>
      </details>
      <details style="margin-bottom:0.75rem;">
        <summary style="cursor:pointer; font-weight:500;">What Ruby version is required?</summary>
        <p style="margin-top:0.5rem; color:var(--text-muted); padding-left:1rem;">Ruby 3.0+ with Sinatra installed.</p>
      </details>
      <details>
        <summary style="cursor:pointer; font-weight:500;">Can I deploy this?</summary>
        <p style="margin-top:0.5rem; color:var(--text-muted); padding-left:1rem;">Absolutely — works on any platform that runs Ruby.</p>
      </details>
    </div>
  </div>
</div>

<script>
  function submitForm(e) {
    e.preventDefault();
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('form-success').style.display = 'block';
  }
</script>
